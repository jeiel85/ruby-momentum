<% content_for :title, "Posts" %>

<div class="w-full">
  <div class="flex justify-between items-center mb-10">
    <h1 class="text-4xl font-black text-white tracking-tight">Recent Feed</h1>
    <%= link_to new_post_path, class: "flex items-center px-6 py-3 bg-indigo-600 hover:bg-indigo-500 text-white rounded-2xl font-bold shadow-lg shadow-indigo-500/20 transition hover:-translate-y-0.5" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
      Write Momentum
    <% end %>
  </div>

  <div id="posts" class="space-y-6">
    <%= turbo_stream_from "posts" %>
    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <div class="glass p-1 rounded-[2.5rem] shadow-2xl transition hover:scale-[1.01] duration-300 border-white/5">
          <%= render post %>
          <div class="px-8 pb-8 flex space-x-3">
            <%= link_to "View Details", post, class: "px-6 py-2 bg-white/5 hover:bg-white/10 text-white font-bold rounded-xl text-xs transition border border-white/10 uppercase tracking-widest" %>
            <% if post.user == current_user %>
              <%= link_to "Edit", edit_post_path(post), class: "px-6 py-2 bg-white/5 hover:bg-white/10 text-white font-bold rounded-xl text-xs transition border border-white/10 uppercase tracking-widest" %>
            <% else %>
              <%= button_to "Tip $5", user_tips_path(post.user), params: { amount: 500 }, class: "px-6 py-2 bg-indigo-600/20 hover:bg-indigo-600/40 text-indigo-400 font-bold rounded-xl text-xs transition border border-indigo-500/20 uppercase tracking-widest cursor-pointer" %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="glass p-20 rounded-[3rem] text-center border-dashed border-white/10">
        <div class="w-16 h-16 bg-white/5 rounded-2xl mx-auto mb-6 flex items-center justify-center text-white/20">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        </div>
        <p class="text-white/40 font-bold italic text-lg tracking-tight leading-relaxed">The feed is silent...<br>Be the first to create momentum!</p>
      </div>
    <% end %>
  </div>
</div>
