<div id="<%= dom_id post %>" class="glass p-8 rounded-[2.5rem] shadow-2xl hover:bg-white/10 transition-all duration-500 mb-6 group border-white/5 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-500/10 blur-3xl -mr-16 -mt-16 group-hover:bg-indigo-500/20 transition-all"></div>

  <div class="flex items-start space-x-5 relative z-10">
    <div class="flex-shrink-0">
      <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-indigo-500/20">
        <%= post.body[0].upcase %>
      </div>
    </div>

    <div class="flex-1">
      <div class="flex items-center justify-between mb-3">
        <h3 class="font-black text-white text-xl tracking-tight">Post Artist</h3>
        <div class="flex items-center gap-2">
          <span class="text-indigo-400/60 text-xs font-bold uppercase tracking-widest"><%= time_ago_in_words(post.created_at) %> ago</span>
          <% if user_signed_in? && current_user != post.user %>
            <button id="report-dropdown-<%= post.id %>" class="text-white/20 hover:text-red-400 transition" onclick="toggleReportMenu('<%= post.id %>')">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"/></svg>
            </button>
            <div id="report-menu-<%= post.id %>" class="hidden absolute right-0 mt-2 w-48 bg-gray-900 border border-white/10 rounded-lg shadow-xl z-50">
              <%= button_to post_reports_path(post), method: :post, params: { report: { reason: :spam } }, class: "block w-full text-left px-4 py-2 text-white/70 hover:bg-white/10 text-sm" do %>
                <span class="text-red-400"> Spam</span>
              <% end %>
              <%= button_to post_reports_path(post), method: :post, params: { report: { reason: :inappropriate } }, class: "block w-full text-left px-4 py-2 text-white/70 hover:bg-white/10 text-sm" do %>
                <span class="text-orange-400"> Inappropriate</span>
              <% end %>
              <%= button_to post_reports_path(post), method: :post, params: { report: { reason: :harassment } }, class: "block w-full text-left px-4 py-2 text-white/70 hover:bg-white/10 text-sm" do %>
                <span class="text-yellow-400"> Harassment</span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
      
      <p class="text-white/80 leading-relaxed text-lg mb-6 font-medium">
        <%= post.body %>
      </p>

      <% if post.image.attached? %>
        <div class="mt-4 rounded-3xl overflow-hidden border border-white/10 shadow-2xl relative group/img">
          <%= image_tag post.image, class: "w-full max-h-[450px] object-cover hover:scale-105 transition-transform duration-700" %>
          <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
        </div>
      <% end %>
      
      <div class="mt-6 pt-6 border-t border-white/5 flex items-center space-x-6">
        <div class="flex items-center text-white/40 text-sm hover:text-indigo-400 transition cursor-pointer group/action">
          <svg class="w-5 h-5 mr-2 group-hover/action:scale-110 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          <span class="font-bold">2.4k</span>
        </div>
        <div class="flex items-center text-white/40 text-sm hover:text-blue-400 transition cursor-pointer group/action">
          <svg class="w-5 h-5 mr-2 group-hover/action:scale-110 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          <span class="font-bold">128</span>
        </div>
      </div>
    </div>
  </div>
</div>
